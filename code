            </div>
            <div class="stat-item">
                <div class="stat-number">40%</div>
                <div class="stat-label">Jóvenes han abandonado un juego por toxicidad</div>
            </div>
        </div>

        <!-- ===== SECCIÓN DE GRÁFICOS ===== -->
        <div class="charts-section">
            <h2><i class="fas fa-chart-bar"></i> Datos Estadísticos</h2>
            <p class="subtitle">Visualización de las problemáticas en la comunidad gamer</p>
            <div class="charts-grid">
                <div class="chart-box">
                    <h3>Robo de cuentas por plataforma</h3>
                    <canvas id="chartRobo"></canvas>
                </div>
                <div class="chart-box">
                    <h3>Tipos de toxicidad en partidas</h3>
                    <canvas id="chartToxicidad"></canvas>
                </div>
            </div>
        </div>

        <!-- ===== SECCIÓN DE RECURSOS ===== -->
        <div class="resources-section" id="recursos">
