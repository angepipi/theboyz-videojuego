    </div>

    <!-- ===== SCRIPTS ===== -->
    <script>
        // ===== MENÚ HAMBURGUESA =====
        const menuToggle = document.getElementById('menuToggle');
        const navLinks = document.getElementById('navLinks');

        menuToggle.addEventListener('click', () => {
            navLinks.classList.toggle('active');
        });

        // Cerrar menú al hacer clic en un enlace
        document.querySelectorAll('.nav-links a').forEach(link => {
            link.addEventListener('click', () => {
                navLinks.classList.remove('active');
            });
        });

        // ===== GRÁFICOS CON CHART.JS =====
        document.addEventListener('DOMContentLoaded', function() {

            // Gráfico 1: Robo de cuentas por plataforma
            const ctx1 = document.getElementById('chartRobo').getContext('2d');
            new Chart(ctx1, {
                type: 'bar',
                data: {
                    labels: ['Steam', 'Epic Games', 'Riot Games', 'Blizzard', 'Otros'],
                    datasets: [{
                        label: 'Cuentas robadas (%)',
                        data: [32, 24, 18, 14, 12],
                        backgroundColor: [
                            'rgba(255, 71, 87, 0.8)',
                            'rgba(255, 71, 87, 0.6)',
                            'rgba(255, 71, 87, 0.4)',
                            'rgba(255, 71, 87, 0.3)',
                            'rgba(255, 71, 87, 0.2)'
                        ],
                        borderColor: '#ff4757',
                        borderWidth: 2,
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            labels: {
                                color: '#8a9bb8',
                                font: { size: 12 }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 40,
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { color: '#6a7f9e' }
                        },
                        x: {
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { color: '#6a7f9e' }
                        }
                    }
                }
            });

            // Gráfico 2: Tipos de toxicidad en partidas
            const ctx2 = document.getElementById('chartToxicidad').getContext('2d');
            new Chart(ctx2, {
                type: 'doughnut',
                data: {
                    labels: ['Insultos', 'Machismo', 'Amenazas', 'Discriminación', 'Acoso'],
                    datasets: [{
                        data: [35, 28, 18, 12, 7],
                        backgroundColor: [
                            'rgba(255, 165, 2, 0.8)',
                            'rgba(255, 165, 2, 0.6)',
                            'rgba(255, 165, 2, 0.4)',
                            'rgba(255, 165, 2, 0.3)',
                            'rgba(255, 165, 2, 0.2)'
                        ],
                        borderColor: '#ffa502',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: '#8a9bb8',
                                font: { size: 12 },
                                padding: 16
                            }
                        }
                    }
                }
            });

        });
    </script>

